          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Niet alle platforms geven feedback bij bepaalde typen"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не все платформы будут воспроизводить вибрацию в ответ на определенные типы обратной связи"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Toutes les plateformes ne diffusent pas de commentaires en réponse à certains types"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Belirli türlere yanıt olarak tüm platformlar geri bildirim oynatmaz"
